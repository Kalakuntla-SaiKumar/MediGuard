# MediGuard Environment Configuration

# ============================================
# SUPABASE CONFIGURATION (For Production/Deployment)
# ============================================
# Leave empty or comment out to use SQLite (local development)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ============================================
# FLASK CONFIGURATION
# ============================================

FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production-2026

# Security cookies (set to True in production with HTTPS)
SESSION_COOKIE_SECURE=False

# Comma-separated origins for browser access when frontend and backend are on different domains
# Example: CORS_ORIGINS=https://mediguard.app,https://www.mediguard.app
CORS_ORIGINS=

# ============================================
# EMAIL CONFIGURATION (Gmail for password reset)
# ============================================
# You'll need to generate an app-specific password
# See: https://support.google.com/accounts/answer/185833

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ============================================
# AI CONFIGURATION (Groq for medical insights)
# ============================================
# Get API key from: https://console.groq.com

GROQ_KEY=your-groq-api-key-here

# ============================================
# NOTES
# ============================================
# 1. For local development: Leave SUPABASE_* variables empty, SQLite will be used
# 2. For production: Fill in all SUPABASE_* variables
# 3. Never commit this file with real credentials to git
# 4. Be sure to add this to .gitignore
